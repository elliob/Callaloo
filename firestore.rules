rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function authed() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function memberDoc(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId)/members/$(uid()));
    }

    function isMember(householdId) {
      return exists(/databases/$(database)/documents/households/$(householdId)/members/$(uid()));
    }

    function isAdmin(householdId) {
      return isMember(householdId)
        && memberDoc(householdId).data.get('role', '') == 'admin';
    }

    function isParent(householdId) {
      return isMember(householdId)
        && memberDoc(householdId).data.get('role', '') == 'parent';
    }

    function householdDoc(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId));
    }

    // Fallback when users/{uid} or members/{uid} drift (manual edits, partial migrations).
    // Household doc is only created/updated by Cloud Functions / Admin SDK in this app.
    function isPrimaryAdminOfHousehold(householdId) {
      let h = householdDoc(householdId);
      return authed()
        && exists(/databases/$(database)/documents/households/$(householdId))
        && h.data.get('primaryAdminUid', '') == uid();
    }

    // users/{uid} is written by Cloud Functions / Admin SDK. Use it as a safe fallback when
    // members/{uid} drifts for this household.
    function hasRoleAccessToHousehold(householdId, allowedRoles) {
      let u = get(/databases/$(database)/documents/users/$(uid()));
      let hid = u.data.get('householdId', '');
      let role = u.data.get('role', '');
      return authed()
        && exists(/databases/$(database)/documents/users/$(uid()))
        && hid == householdId
        && role in allowedRoles;
    }

    function hasAdminAccessToHousehold(householdId) {
      return hasRoleAccessToHousehold(householdId, ['admin']);
    }

    function hasReadAccessToHousehold(householdId) {
      return hasRoleAccessToHousehold(householdId, ['admin', 'parent']);
    }

    // Prefer users/{uid} (Cloud Functions–written) first so OR short-circuits before member get().
    function canAdminHousehold(householdId) {
      return hasAdminAccessToHousehold(householdId)
        || isAdmin(householdId)
        || isPrimaryAdminOfHousehold(householdId);
    }

    // Client may merge email, displayName, FCM fields, etc. Only Cloud Functions may set/change
    // householdId and role (via Admin SDK). Diff-based check avoids brittle equality on merges.
    function userTenantFieldsUnchanged() {
      let locked = ['householdId', 'role'];
      let d = request.resource.data.diff(resource.data);
      return !d.changedKeys().hasAny(locked)
        && !d.addedKeys().hasAny(locked)
        && !d.removedKeys().hasAny(locked);
    }

    match /users/{userId} {
      allow read: if authed() && userId == uid();

      allow create: if authed() && userId == uid()
        && !request.resource.data.keys().hasAny(['householdId', 'role']);

      allow update: if authed() && userId == uid() && userTenantFieldsUnchanged();
    }

    match /households/{householdId} {
      allow read: if authed()
        && (isMember(householdId)
          || hasReadAccessToHousehold(householdId)
          || isPrimaryAdminOfHousehold(householdId));
      allow create, delete: if false;
      allow update: if authed() && canAdminHousehold(householdId);

      match /members/{memberId} {
        allow read: if authed()
          && (isMember(householdId)
            || hasReadAccessToHousehold(householdId)
            || isPrimaryAdminOfHousehold(householdId));
        allow write: if false;
      }

      match /listItems/{itemId} {
        allow read: if authed()
          && (isMember(householdId)
            || hasReadAccessToHousehold(householdId)
            || isPrimaryAdminOfHousehold(householdId));
        allow write: if authed() && canAdminHousehold(householdId);
      }

      match /orderRequests/{orderId} {
        allow read: if authed()
          && (isMember(householdId)
            || hasReadAccessToHousehold(householdId)
            || isPrimaryAdminOfHousehold(householdId));

        allow create: if authed() && isParent(householdId)
          && request.resource.data.status == 'pending'
          && request.resource.data.createdByParentUid == uid();

        allow update: if authed() && canAdminHousehold(householdId)
          && resource.data.status == 'pending'
          && request.resource.data.status in ['ordered', 'cancelled'];

        allow delete: if false;
      }
    }

    match /invites/{inviteId} {
      allow read, write: if false;
    }
  }
}
